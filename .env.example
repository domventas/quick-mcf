# =============================================================================
# MCF Backend — Environment Configuration
# =============================================================================

# Environment mode: "mock" (no network), "sandbox", or "production"
ENVIRONMENT=mock

# Amazon SP-API credentials (not needed for mock mode)
SP_API_REFRESH_TOKEN=
SP_API_CLIENT_ID=
SP_API_CLIENT_SECRET=
SP_API_AWS_ACCESS_KEY=
SP_API_AWS_SECRET_KEY=
SP_API_ROLE_ARN=
SP_API_MARKETPLACE_ID=ATVPDKIKX0DER
SP_API_REGION=NA

# Safety — set to False only when you're ready to make real Amazon calls
DRY_RUN=True

# Database
DATABASE_URL=sqlite+aiosqlite:///./mcf.db

# Sync intervals
INVENTORY_SYNC_INTERVAL_HOURS=3
ORDER_POLL_INTERVAL_MINUTES=10

# Quicklly integration (disabled by default)
QUICKLLY_API_URL=
QUICKLLY_API_KEY=
QUICKLLY_PUSH_ENABLED=False
